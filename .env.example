# ===========================================
# Press Release Pipeline - Environment Config
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# REQUIRED - Core Configuration
# -------------------------------------------

# Anthropic API key for AI classification
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Flask secret key for session encryption
# Generate with: openssl rand -hex 32
FLASK_SECRET_KEY=your-secret-key-here

# -------------------------------------------
# AWS Configuration (for cloud deployment)
# -------------------------------------------

# AWS Region
AWS_REGION=us-east-1

# Option 1: Use AWS CLI profile
# AWS_PROFILE=default

# Option 2: Use access keys directly (not recommended for production)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# -------------------------------------------
# OPTIONAL - Brave Search API
# -------------------------------------------
# For news discovery beyond IR emails
# Get your key at: https://brave.com/search/api/

# BRAVE_API_KEY=your-brave-key-here

# -------------------------------------------
# OPTIONAL - Email Sending
# -------------------------------------------
# Configure if you want to send newsletter emails

# Email provider: 'ses' (AWS) or 'gmail'
# EMAIL_PROVIDER=ses

# Sender address (must be verified in SES)
# EMAIL_FROM=newsletter@your-domain.com

# Newsletter recipients (comma-separated)
# NEWSLETTER_RECIPIENTS=you@email.com,team@company.com

# Gmail-specific (if using Gmail instead of SES)
# GMAIL_APP_PASSWORD=your-app-password

# -------------------------------------------
# OPTIONAL - Scraper Configuration
# -------------------------------------------

# HTTP Timeouts (seconds)
# SCRAPER_TIMEOUT_SHORT=5
# SCRAPER_TIMEOUT_MEDIUM=10
# SCRAPER_TIMEOUT_LONG=15

# Rate Limiting (seconds between requests)
# SCRAPER_RATE_LIMIT_DELAY=2

# -------------------------------------------
# OPTIONAL - Local Development
# -------------------------------------------

# Use SQLite instead of DynamoDB
# USE_DYNAMODB=false

# Local database path
# DATABASE_URL=sqlite:///data/press_releases.db

# Enable debug mode (never in production!)
# DEBUG=true

# -------------------------------------------
# OPTIONAL - Feature Flags
# -------------------------------------------

# Enable/disable pipeline components
# ENABLE_BRAVE_SEARCH=true
# ENABLE_SEC_FILINGS=true
# ENABLE_RSS_FEEDS=true

# Confidence threshold for company matching (0-100)
# CONFIDENCE_THRESHOLD=70
