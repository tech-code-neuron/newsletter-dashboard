# direnv configuration for REIT Newsletter project
# Auto-runs when you cd into this directory
#
# To enable direnv:
#   1. Install: brew install direnv
#   2. Add to ~/.zshrc: eval "$(direnv hook zsh)"
#   3. Run: direnv allow
#
# This will automatically run session-start.sh when entering the directory

# Check if this is a new session (not already run in this shell)
if [ -z "$REIT_SESSION_STARTED" ]; then
    export REIT_SESSION_STARTED=1

    # Run session start check
    if [ -f "scripts/session-start.sh" ]; then
        echo ""
        echo "🔄 Running automatic session start check (direnv)..."
        echo ""
        bash scripts/session-start.sh
    fi
fi
